<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="PontoMauiApp.MainPage"
             Title="Registro de Ponto"
             BackgroundColor="White">

    <ScrollView VerticalOptions="FillAndExpand">
        <VerticalStackLayout Padding="20" Spacing="20" VerticalOptions="FillAndExpand">

            <!-- Cabeçalho -->
            <Label Text="Olá, Maria!"
                   FontSize="28"
                   FontAttributes="Bold"
                   HorizontalOptions="Start" />

            <Label Text="Registre seu ponto com sua localização"
                   FontSize="16"
                   TextColor="Gray" />

            <!-- Card de registro -->
            <Frame BackgroundColor="#F0F8FF" 
                   CornerRadius="16" 
                   Padding="20"
                   HasShadow="True">

                <VerticalStackLayout Spacing="15">
                    <Label Text="Ative sua localização para registrar o ponto"
                           FontSize="16"
                           TextColor="#333333" />

                    <Button Text="📍 REGISTRAR PONTO (ENTRADA)"
                            FontSize="18"
                            HeightRequest="68"
                            BackgroundColor="#2196F3"
                            TextColor="White"
                            CornerRadius="12"
                            Clicked="BtnEntrada_Clicked" />

                    <Button Text="📍 REGISTRAR PONTO (SAÍDA)"
                            FontSize="18"
                            HeightRequest="68"
                            BackgroundColor="#FF9800"
                            TextColor="White"
                            CornerRadius="12"
                            Clicked="BtnSaida_Clicked"
                            Margin="0,8,0,0" />
                </VerticalStackLayout>
            </Frame>

            <!-- Lista de registros recentes -->
            <Label Text="Registros recentes"
                   FontSize="20"
                   FontAttributes="Bold"
                   Margin="0,10,0,0" />

            <CollectionView x:Name="listaRegistros"
                            HeightRequest="380"
                            ItemsSource="{Binding Registros}"
                            VerticalOptions="FillAndExpand">

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Frame CornerRadius="12" 
                               Padding="15" 
                               Margin="0,6"
                               HasShadow="True"
                               BackgroundColor="White">
                            <VerticalStackLayout Spacing="6">
                                <HorizontalStackLayout>
                                    <Label Text="{Binding Horario, StringFormat='{0:dd/MM/yyyy}'}"
                                           FontAttributes="Bold"
                                           TextColor="#333" />
                                    <Label Text="{Binding Horario, StringFormat=' • {0:HH:mm}'}"
                                           Margin="10,0,0,0"
                                           TextColor="#666" />
                                </HorizontalStackLayout>

                                <Label Text="{Binding Latitude, StringFormat='Lat: {0:F6}'}" 
                                       FontSize="14" />
                                <Label Text="{Binding Longitude, StringFormat='Lon: {0:F6}'}" 
                                       FontSize="14" />

                                <Label Text="{Binding Observacao}"
                                       TextColor="#555"
                                       FontSize="14" />

                                <Button Text="🗺️ Ver no mapa"
                                        BackgroundColor="Transparent"
                                        TextColor="#2196F3"
                                        FontSize="15"
                                        FontAttributes="Bold"
                                        HorizontalOptions="End"
                                        Clicked="VerNoMapa_Clicked"
                                        CommandParameter="{Binding .}" />
                            </VerticalStackLayout>
                        </Frame>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Mensagem quando não há registros -->
            <Label x:Name="lblEmpty"
                   Text="Nenhum registro ainda"
                   IsVisible="False"
                   TextColor="Gray"
                   HorizontalOptions="Center"
                   Margin="0,20" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>